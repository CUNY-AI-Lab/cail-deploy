DEPLOY_API_TOKEN=replace-with-local-api-token
# Signs short-lived CSRF form tokens for the browser project-control UI only. The MCP
# OAuth surface is now handled by @cloudflare/workers-oauth-provider, which manages its
# own encryption keys inside the OAUTH_KV namespace and does not require an HMAC secret.
PROJECT_CONTROL_FORM_TOKEN_SECRET=replace-with-project-control-form-token-secret
CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com
CLOUDFLARE_ACCESS_AUD=replace-with-access-aud-tag
CLOUDFLARE_ACCESS_ALLOWED_EMAIL_DOMAINS=cuny.edu
CLOUDFLARE_ACCESS_ALLOWED_EMAILS=
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_WITH_PRIVATE_KEY\n-----END PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret
BUILD_RUNNER_TOKEN=replace-with-runner-shared-secret
CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
